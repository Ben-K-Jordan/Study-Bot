generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id             String       @id @default(uuid())
  sessionId      String       @unique @map("session_id")
  userId         String       @map("user_id")
  courseId        String       @map("course_id")
  courseName     String       @map("course_name")
  examId         String       @map("exam_id")
  examName       String       @map("exam_name")
  mode           String
  topicScope     String       @map("topic_scope")
  objectives     Json?
  targetOutcome  Json?        @map("target_outcome")
  breakProtocol  Json?        @map("break_protocol")
  resources      Json?
  plannedMinutes Int          @map("planned_minutes")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  runs           SessionRun[]

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)], map: "sessions_user_created_idx")
  @@map("sessions")
}

model SessionRun {
  id            String             @id @default(uuid())
  runId         String             @unique @map("run_id")
  sessionId     String             @map("session_id")
  userId        String             @map("user_id")
  mode          String             @default("RETRIEVAL")
  phase         String             @default("ACTIVE") // ACTIVE | EXAM | REVIEW | COMPLETE
  status        String             @default("CREATED") // CREATED | ACTIVE | PAUSED | COMPLETED
  startedAt     DateTime?          @map("started_at")
  endedAt       DateTime?          @map("ended_at")
  currentIndex  Int                @default(0) @map("current_index")
  promptCount   Int                @default(0) @map("prompt_count")
  answeredCount Int?               @map("answered_count") // EXAM_SIM: prompts answered
  scoredCount   Int?               @map("scored_count")   // EXAM_SIM: prompts scored in review
  prompts       Json               // Array of generated prompts (legacy, kept for backward compat)
  policies      Json               @default("{}") // Scoring/hint/error-log policies
  metrics       Json               @default("{}") // Rolling stats
  breakState    Json               @default("{}") @map("break_state")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  session       Session            @relation(fields: [sessionId], references: [sessionId])
  attempts      SessionAttempt[]
  errorLogs     SessionErrorLog[]
  runPrompts    SessionRunPrompt[]

  @@index([userId, status])
  @@index([userId, createdAt(sort: Desc)], map: "session_runs_user_created_idx")
  @@index([sessionId])
  @@map("session_runs")
}

model SessionAttempt {
  id                  String     @id @default(uuid())
  runId               String     @map("run_id")
  promptIndex         Int        @map("prompt_index")
  promptId            String     @map("prompt_id")
  promptText          String     @map("prompt_text")
  userAnswer          String     @map("user_answer")
  selfScore           String?    @map("self_score") // CORRECT | PARTIAL | INCORRECT | null (EXAM phase)
  timeToAnswerSeconds Int?       @map("time_to_answer_seconds")
  confidenceRating    Int?       @map("confidence_rating") // 1-5 pre-answer confidence
  selfExplanation     String?    @map("self_explanation") // Student's explain-back after feedback
  generatedExample    String?    @map("generated_example") // Student's own example (generation effect)
  createdAt           DateTime   @default(now()) @map("created_at")

  run                 SessionRun      @relation(fields: [runId], references: [runId])
  citations           AttemptCitation[]

  @@unique([runId, promptIndex], map: "session_attempts_run_id_prompt_index_key")
  @@index([runId])
  @@index([runId, createdAt])
  @@map("session_attempts")
}

model SessionErrorLog {
  id               String     @id @default(uuid())
  runId            String     @map("run_id")
  userId           String     @default("") @map("user_id")
  promptIndex      Int        @map("prompt_index")
  errorType        String     @map("error_type") // MISCONCEPTION | PROCEDURE | CARELESS | MEMORY | UNKNOWN
  correctionRule   String     @map("correction_rule")
  variantQuestion  String?    @map("variant_question")
  resolvedAt       DateTime?  @map("resolved_at") @db.Timestamptz
  resolvedByRunId  String?    @map("resolved_by_run_id")
  createdAt        DateTime   @default(now()) @map("created_at")

  run              SessionRun @relation(fields: [runId], references: [runId])

  @@index([runId])
  @@index([userId, resolvedAt, createdAt(sort: Desc)], map: "session_error_logs_user_unresolved_idx")
  @@map("session_error_logs")
}

model SessionRunPrompt {
  id          String     @id @default(uuid())
  runId       String     @map("run_id")
  promptIndex Int        @map("prompt_index")
  objectiveId String?    @map("objective_id")
  text        String
  difficulty  Int        @default(1)
  sourceType  String     @default("GENERATED") @map("source_type") // GENERATED | PRACTICE_QUESTION | ERROR_LOG
  sourceRefId String?    @map("source_ref_id")
  meta        Json?
  createdAt   DateTime   @default(now()) @map("created_at")

  run         SessionRun @relation(fields: [runId], references: [runId], onDelete: Cascade)

  @@unique([runId, promptIndex], map: "session_run_prompts_run_prompt_key")
  @@index([runId, promptIndex])
  @@map("session_run_prompts")
}

model StudyPlan {
  id         String          @id @default(uuid())
  planId     String          @unique @map("plan_id")
  userId     String          @map("user_id")
  courseId    String          @map("course_id")
  courseName String          @map("course_name")
  examId     String          @map("exam_id")
  examName   String          @map("exam_name")
  examDate   DateTime        @map("exam_date") @db.Date
  timezone   String          @default("America/New_York")
  startDate  DateTime        @map("start_date") @db.Date
  endDate    DateTime        @map("end_date") @db.Date
  config     Json            @default("{}")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  items         StudyPlanItem[]
  publications  PlanCalendarPublication[]

  @@index([userId])
  @@index([userId, examDate], map: "study_plans_user_exam_date_idx")
  @@map("study_plans")
}

// ---- Knowledge Layer ----

model ContentDocument {
  id               String         @id @default(uuid())
  userId           String         @map("user_id")
  namespace        String         // COURSE | RESEARCH
  courseName       String?        @map("course_name")
  examName         String?        @map("exam_name")
  title            String
  originalFilename String         @map("original_filename")
  mimeType         String         @map("mime_type")
  storageKey       String         @map("storage_key")
  contentHash      String         @map("content_hash")
  status           String         @default("UPLOADED") // UPLOADED | PROCESSED | FAILED
  errorMessage     String?        @map("error_message")
  summary          String?
  suggestedQuestions Json?        @map("suggested_questions") // Array of strings
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  chunks           ContentChunk[]
  evidencePapers   EvidencePaper[]
  flashcardDecks   FlashcardDeck[]

  @@unique([userId, contentHash], map: "content_documents_user_hash_key")
  @@index([userId, namespace, courseName, examName], map: "content_documents_user_ns_course_exam_idx")
  @@map("content_documents")
}

model ContentChunk {
  id                String            @id @default(uuid())
  documentId        String            @map("document_id")
  ordinal           Int
  pageNumber        Int?              @map("page_number")
  text              String
  textHash          String            @map("text_hash")
  embeddingStatus   String            @default("NONE") @map("embedding_status") // NONE | PENDING | READY | FAILED
  embeddingModel    String?           @map("embedding_model")
  embeddingDim      Int?              @map("embedding_dim")
  embeddingUpdatedAt DateTime?        @map("embedding_updated_at") @db.Timestamptz
  // embedding vector stored via raw SQL (pgvector); Prisma cannot represent vector natively
  createdAt         DateTime          @default(now()) @map("created_at")

  document   ContentDocument   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  citations  AttemptCitation[]
  anchors    ObjectiveAnchor[]

  @@unique([documentId, ordinal], map: "content_chunks_doc_ordinal_key")
  @@index([embeddingStatus])
  @@map("content_chunks")
}

model ObjectiveAnchor {
  id          String       @id @default(uuid())
  userId      String       @map("user_id")
  courseName  String       @map("course_name")
  examName    String       @default("") @map("exam_name")
  objectiveId String       @map("objective_id")
  chunkId     String       @map("chunk_id")
  rank        Int
  createdAt   DateTime     @default(now()) @map("created_at")

  chunk       ContentChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@unique([userId, courseName, examName, objectiveId, chunkId], map: "objective_anchors_unique_key")
  @@index([userId, courseName, examName, objectiveId], map: "objective_anchors_lookup_idx")
  @@map("objective_anchors")
}

model PracticeSet {
  id         String             @id @default(uuid())
  userId     String             @map("user_id")
  courseName String             @map("course_name")
  examName   String?            @map("exam_name")
  title      String
  createdAt  DateTime           @default(now()) @map("created_at")

  questions  PracticeQuestion[]

  @@index([userId, courseName, examName], map: "practice_sets_user_course_exam_idx")
  @@map("practice_sets")
}

model PracticeQuestion {
  id            String      @id @default(uuid())
  practiceSetId String      @map("practice_set_id")
  kind          String      // SHORT_ANSWER | MCQ | CODING
  promptText    String      @map("prompt_text")
  answerKey     String?     @map("answer_key")
  solutionSteps String?     @map("solution_steps")
  tags          Json?
  createdAt     DateTime    @default(now()) @map("created_at")

  practiceSet   PracticeSet @relation(fields: [practiceSetId], references: [id], onDelete: Cascade)

  @@index([practiceSetId])
  @@map("practice_questions")
}

model EvidencePaper {
  id         String          @id @default(uuid())
  userId     String          @map("user_id")
  title      String
  authors    String?
  year       Int?
  venue      String?
  documentId String          @map("document_id")
  tags       Json?
  createdAt  DateTime        @default(now()) @map("created_at")

  document   ContentDocument @relation(fields: [documentId], references: [id])
  cards      EvidenceCard[]

  @@index([userId])
  @@map("evidence_papers")
}

model EvidenceCard {
  id                 String        @id @default(uuid())
  evidencePaperId    String        @map("evidence_paper_id")
  claim              String
  recommendation     String
  boundaryConditions String?       @map("boundary_conditions")
  strength           String        // WEAK | MODERATE | STRONG
  tags               Json?
  createdAt          DateTime      @default(now()) @map("created_at")

  paper              EvidencePaper @relation(fields: [evidencePaperId], references: [id], onDelete: Cascade)

  @@index([evidencePaperId])
  @@index([strength], map: "evidence_cards_strength_idx")
  @@map("evidence_cards")
}

model AttemptCitation {
  id        String         @id @default(uuid())
  attemptId String         @map("attempt_id")
  chunkId   String         @map("chunk_id")
  rank      Int
  snippet   String
  createdAt DateTime       @default(now()) @map("created_at")

  attempt   SessionAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  chunk     ContentChunk   @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@unique([attemptId, chunkId], map: "attempt_citations_attempt_chunk_key")
  @@index([attemptId])
  @@index([chunkId])
  @@map("attempt_citations")
}

model StudyPlanItem {
  id                String    @id @default(uuid())
  planId            String    @map("plan_id")
  sessionId         String    @map("session_id")
  dayIndex          Int       @map("day_index")
  startTime         DateTime  @map("start_time") @db.Timestamptz
  endTime           DateTime  @map("end_time") @db.Timestamptz
  status            String    @default("SCHEDULED") // SCHEDULED | IN_PROGRESS | DONE | MISSED | SKIPPED | RESCHEDULED
  locked            Boolean   @default(false)
  completedRunId    String?   @map("completed_run_id")
  completedAt       DateTime? @map("completed_at") @db.Timestamptz
  missedAt          DateTime? @map("missed_at") @db.Timestamptz
  lastRescheduledAt DateTime? @map("last_rescheduled_at") @db.Timestamptz
  originalStartAt   DateTime? @map("original_start_at") @db.Timestamptz
  originalEndAt     DateTime? @map("original_end_at") @db.Timestamptz
  createdAt         DateTime  @default(now()) @map("created_at")

  plan            StudyPlan              @relation(fields: [planId], references: [planId])
  externalEvents  PlanItemExternalEvent[]

  @@unique([planId, sessionId], map: "study_plan_items_plan_id_session_id_key")
  @@index([planId])
  @@index([planId, startTime], map: "study_plan_items_plan_start_idx")
  @@index([planId, status], map: "study_plan_items_plan_status_idx")
  @@map("study_plan_items")
}

model PlanReflowAudit {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  planId           String   @map("plan_id")
  reason           String   // MANUAL | AUTO_MISSED | AUTO_RESCHEDULE
  algorithmVersion String   @default("v1") @map("algorithm_version")
  inputSummary     Json     @map("input_summary")
  changes          Json     // Array of { itemId, action, before, after }
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([planId, createdAt(sort: Desc)], map: "plan_reflow_audits_plan_created_idx")
  @@map("plan_reflow_audits")
}

// ---- Calendar Publication Tracking ----

model PlanCalendarPublication {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  planId       String    @map("plan_id")
  provider     String    @default("GOOGLE") // GOOGLE
  calendarId   String    @map("calendar_id")
  status       String    @default("NOT_PUBLISHED") // NOT_PUBLISHED | PUBLISHED | PARTIAL | FAILED | UNPUBLISHED
  publishedAt  DateTime? @map("published_at") @db.Timestamptz
  lastSyncedAt DateTime? @map("last_synced_at") @db.Timestamptz
  lastError    String?   @map("last_error")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  plan         StudyPlan @relation(fields: [planId], references: [planId])

  @@unique([provider, planId], map: "plan_calendar_publications_provider_plan_key")
  @@index([userId, provider])
  @@index([planId])
  @@map("plan_calendar_publications")
}

model PlanItemExternalEvent {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  planId          String    @map("plan_id")
  planItemId      String    @map("plan_item_id")
  provider        String    @default("GOOGLE") // GOOGLE
  calendarId      String    @map("calendar_id")
  eventId         String    @map("event_id")
  htmlLink        String?   @map("html_link")
  etag            String?
  remoteUpdatedAt DateTime? @map("remote_updated_at") @db.Timestamptz
  lastSyncedHash  String    @map("last_synced_hash")
  lastSyncedAt    DateTime  @map("last_synced_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  planItem        StudyPlanItem @relation(fields: [planItemId], references: [id])

  @@unique([provider, planItemId], map: "plan_item_external_events_provider_item_key")
  @@index([provider, planId])
  @@index([userId, provider])
  @@index([calendarId, eventId])
  @@map("plan_item_external_events")
}

// ---- Google Calendar Integration ----

model GoogleIntegration {
  id                      String    @id @default(uuid())
  userId                  String    @unique @map("user_id")
  status                  String    @default("CONNECTED") // CONNECTED | DISCONNECTED | ERROR
  connectedEmail          String?   @map("connected_email")
  accessTokenEncrypted    String?   @map("access_token_encrypted")
  refreshTokenEncrypted   String?   @map("refresh_token_encrypted")
  tokenExpiryMs           BigInt    @default(0) @map("token_expiry_ms")
  scopeString             String    @default("") @map("scope_string")
  calendarIdSelected      String    @default("primary") @map("calendar_id_selected")
  busyCalendarIds         String    @default("primary") @map("busy_calendar_ids") // comma-separated
  availabilityLookaheadDays Int     @default(14) @map("availability_lookahead_days")
  timezone                String?
  lastRefreshAt           DateTime? @map("last_refresh_at") @db.Timestamptz
  lastErrorCode           String?   @map("last_error_code")
  lastErrorMessage        String?   @map("last_error_message")
  lastHealthyAt           DateTime? @map("last_healthy_at") @db.Timestamptz
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@map("google_integrations")
}

model OAuthState {
  id        String   @id @default(uuid())
  state     String   @unique
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@map("oauth_states")
}

// ---- AI Control Plane ----

model AiCallLog {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  task          String   // EMBED_TEXTS | ANSWER_WITH_CITATIONS | GENERATE_VARIANT_QUESTION | SUGGEST_ERROR_TYPE
  model         String
  promptVersion String   @map("prompt_version")
  cacheHit      Boolean  @map("cache_hit")
  latencyMs     Int      @map("latency_ms")
  tokenIn       Int?     @map("token_in")
  tokenOut      Int?     @map("token_out")
  costUsdMicros BigInt?  @map("cost_usd_micros")
  status        String   // OK | ERROR
  errorCode     String?  @map("error_code")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([task, createdAt])
  @@map("ai_call_logs")
}

model AiCache {
  keyHash          String   @id @map("key_hash")
  task             String
  model            String
  promptVersion    String   @map("prompt_version")
  inputFingerprint String   @map("input_fingerprint")
  outputJson       Json     @map("output_json")
  createdAt        DateTime @default(now()) @map("created_at")
  expiresAt        DateTime @map("expires_at")
  hitCount         Int      @default(0) @map("hit_count")
  lastHitAt        DateTime? @map("last_hit_at")

  @@index([task, expiresAt])
  @@map("ai_cache")
}

model JobQueue {
  id          String    @id @default(uuid())
  type        String    // EMBED_CHUNK_BATCH
  payload     Json
  status      String    @default("PENDING") // PENDING | RUNNING | SUCCEEDED | FAILED | RETRY
  priority    Int       @default(100)
  runAfter    DateTime  @default(now()) @map("run_after") @db.Timestamptz
  attempts    Int       @default(0)
  maxAttempts Int       @default(5) @map("max_attempts")
  lockedAt    DateTime? @map("locked_at") @db.Timestamptz
  lockedBy    String?   @map("locked_by")
  lastError   String?   @map("last_error")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([status, runAfter, priority])
  @@index([type, status])
  @@map("job_queue")
}

model ObjectiveMastery {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  courseName   String    @map("course_name")
  objectiveKey String    @map("objective_key")
  easeFactor   Float     @default(2.5) @map("ease_factor")
  intervalDays Int       @default(0) @map("interval_days")
  repetitions  Int       @default(0)
  lastAccuracy Float?    @map("last_accuracy")
  lastStudiedAt DateTime? @map("last_studied_at") @db.Timestamptz
  nextDueAt    DateTime?  @map("next_due_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@unique([userId, courseName, objectiveKey], map: "objective_mastery_user_course_key")
  @@index([userId, courseName, nextDueAt])
  @@map("objective_mastery")
}

model StudyGuide {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  courseName String   @map("course_name")
  examName   String?  @map("exam_name")
  guideType  String   @map("guide_type") // KEY_CONCEPTS | FAQ | CHEAT_SHEET
  title      String
  content    Json     // Structured guide content (sections array)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([userId, courseName, examName], map: "study_guides_user_course_exam_idx")
  @@map("study_guides")
}

// ---- Flashcards ----

model FlashcardDeck {
  id           String      @id @default(uuid())
  userId       String      @map("user_id")
  courseName   String      @map("course_name")
  examName     String?     @map("exam_name")
  documentId   String?     @map("document_id")
  title        String
  cardCount    Int         @default(0) @map("card_count")
  createdAt    DateTime    @default(now()) @map("created_at")

  document     ContentDocument? @relation(fields: [documentId], references: [id])
  cards        Flashcard[]

  @@index([userId, courseName, examName], map: "flashcard_decks_user_course_exam_idx")
  @@map("flashcard_decks")
}

model Flashcard {
  id        String   @id @default(uuid())
  deckId    String   @map("deck_id")
  front     String
  back      String
  tags      Json?
  ordinal   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  deck      FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@index([deckId])
  @@map("flashcards")
}
