generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id             String       @id @default(uuid())
  sessionId      String       @unique @map("session_id")
  userId         String       @map("user_id")
  courseId        String       @map("course_id")
  courseName     String       @map("course_name")
  examId         String       @map("exam_id")
  examName       String       @map("exam_name")
  mode           String
  topicScope     String       @map("topic_scope")
  objectives     Json?
  targetOutcome  Json?        @map("target_outcome")
  breakProtocol  Json?        @map("break_protocol")
  resources      Json?
  plannedMinutes Int          @map("planned_minutes")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  runs           SessionRun[]

  @@index([userId])
  @@map("sessions")
}

model SessionRun {
  id            String             @id @default(uuid())
  runId         String             @unique @map("run_id")
  sessionId     String             @map("session_id")
  userId        String             @map("user_id")
  mode          String             @default("RETRIEVAL")
  phase         String             @default("ACTIVE") // ACTIVE | EXAM | REVIEW | COMPLETE
  status        String             @default("CREATED") // CREATED | ACTIVE | PAUSED | COMPLETED
  startedAt     DateTime?          @map("started_at")
  endedAt       DateTime?          @map("ended_at")
  currentIndex  Int                @default(0) @map("current_index")
  promptCount   Int                @default(0) @map("prompt_count")
  answeredCount Int?               @map("answered_count") // EXAM_SIM: prompts answered
  scoredCount   Int?               @map("scored_count")   // EXAM_SIM: prompts scored in review
  prompts       Json               // Array of generated prompts (legacy, kept for backward compat)
  policies      Json               @default("{}") // Scoring/hint/error-log policies
  metrics       Json               @default("{}") // Rolling stats
  breakState    Json               @default("{}") @map("break_state")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  session       Session            @relation(fields: [sessionId], references: [sessionId])
  attempts      SessionAttempt[]
  errorLogs     SessionErrorLog[]
  runPrompts    SessionRunPrompt[]

  @@index([userId, status])
  @@index([sessionId])
  @@map("session_runs")
}

model SessionAttempt {
  id                  String     @id @default(uuid())
  runId               String     @map("run_id")
  promptIndex         Int        @map("prompt_index")
  promptId            String     @map("prompt_id")
  promptText          String     @map("prompt_text")
  userAnswer          String     @map("user_answer")
  selfScore           String?    @map("self_score") // CORRECT | PARTIAL | INCORRECT | null (EXAM phase)
  timeToAnswerSeconds Int?       @map("time_to_answer_seconds")
  createdAt           DateTime   @default(now()) @map("created_at")

  run                 SessionRun      @relation(fields: [runId], references: [runId])
  citations           AttemptCitation[]

  @@unique([runId, promptIndex], map: "session_attempts_run_id_prompt_index_key")
  @@index([runId])
  @@index([runId, createdAt])
  @@map("session_attempts")
}

model SessionErrorLog {
  id               String     @id @default(uuid())
  runId            String     @map("run_id")
  userId           String     @default("") @map("user_id")
  promptIndex      Int        @map("prompt_index")
  errorType        String     @map("error_type") // MISCONCEPTION | PROCEDURE | CARELESS | MEMORY | UNKNOWN
  correctionRule   String     @map("correction_rule")
  variantQuestion  String?    @map("variant_question")
  resolvedAt       DateTime?  @map("resolved_at") @db.Timestamptz
  resolvedByRunId  String?    @map("resolved_by_run_id")
  createdAt        DateTime   @default(now()) @map("created_at")

  run              SessionRun @relation(fields: [runId], references: [runId])

  @@index([runId])
  @@index([userId, resolvedAt, createdAt(sort: Desc)], map: "session_error_logs_user_unresolved_idx")
  @@map("session_error_logs")
}

model SessionRunPrompt {
  id          String     @id @default(uuid())
  runId       String     @map("run_id")
  promptIndex Int        @map("prompt_index")
  objectiveId String?    @map("objective_id")
  text        String
  difficulty  Int        @default(1)
  sourceType  String     @default("GENERATED") @map("source_type") // GENERATED | PRACTICE_QUESTION | ERROR_LOG
  sourceRefId String?    @map("source_ref_id")
  meta        Json?
  createdAt   DateTime   @default(now()) @map("created_at")

  run         SessionRun @relation(fields: [runId], references: [runId], onDelete: Cascade)

  @@unique([runId, promptIndex], map: "session_run_prompts_run_prompt_key")
  @@index([runId, promptIndex])
  @@map("session_run_prompts")
}

model StudyPlan {
  id         String          @id @default(uuid())
  planId     String          @unique @map("plan_id")
  userId     String          @map("user_id")
  courseId    String          @map("course_id")
  courseName String          @map("course_name")
  examId     String          @map("exam_id")
  examName   String          @map("exam_name")
  examDate   DateTime        @map("exam_date") @db.Date
  timezone   String          @default("America/New_York")
  startDate  DateTime        @map("start_date") @db.Date
  endDate    DateTime        @map("end_date") @db.Date
  config     Json            @default("{}")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  items      StudyPlanItem[]

  @@index([userId])
  @@map("study_plans")
}

// ---- Knowledge Layer ----

model ContentDocument {
  id               String         @id @default(uuid())
  userId           String         @map("user_id")
  namespace        String         // COURSE | RESEARCH
  courseName       String?        @map("course_name")
  examName         String?        @map("exam_name")
  title            String
  originalFilename String         @map("original_filename")
  mimeType         String         @map("mime_type")
  storageKey       String         @map("storage_key")
  contentHash      String         @map("content_hash")
  status           String         @default("UPLOADED") // UPLOADED | PROCESSED | FAILED
  errorMessage     String?        @map("error_message")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  chunks           ContentChunk[]
  evidencePapers   EvidencePaper[]

  @@unique([userId, contentHash], map: "content_documents_user_hash_key")
  @@index([userId, namespace, courseName, examName], map: "content_documents_user_ns_course_exam_idx")
  @@map("content_documents")
}

model ContentChunk {
  id         String            @id @default(uuid())
  documentId String            @map("document_id")
  ordinal    Int
  pageNumber Int?              @map("page_number")
  text       String
  textHash   String            @map("text_hash")
  createdAt  DateTime          @default(now()) @map("created_at")

  document   ContentDocument   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  citations  AttemptCitation[]
  anchors    ObjectiveAnchor[]

  @@unique([documentId, ordinal], map: "content_chunks_doc_ordinal_key")
  @@map("content_chunks")
}

model ObjectiveAnchor {
  id          String       @id @default(uuid())
  userId      String       @map("user_id")
  courseName  String       @map("course_name")
  examName    String       @default("") @map("exam_name")
  objectiveId String       @map("objective_id")
  chunkId     String       @map("chunk_id")
  rank        Int
  createdAt   DateTime     @default(now()) @map("created_at")

  chunk       ContentChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@unique([userId, courseName, examName, objectiveId, chunkId], map: "objective_anchors_unique_key")
  @@index([userId, courseName, examName, objectiveId], map: "objective_anchors_lookup_idx")
  @@map("objective_anchors")
}

model PracticeSet {
  id         String             @id @default(uuid())
  userId     String             @map("user_id")
  courseName String             @map("course_name")
  examName   String?            @map("exam_name")
  title      String
  createdAt  DateTime           @default(now()) @map("created_at")

  questions  PracticeQuestion[]

  @@index([userId, courseName, examName], map: "practice_sets_user_course_exam_idx")
  @@map("practice_sets")
}

model PracticeQuestion {
  id            String      @id @default(uuid())
  practiceSetId String      @map("practice_set_id")
  kind          String      // SHORT_ANSWER | MCQ | CODING
  promptText    String      @map("prompt_text")
  answerKey     String?     @map("answer_key")
  solutionSteps String?     @map("solution_steps")
  tags          Json?
  createdAt     DateTime    @default(now()) @map("created_at")

  practiceSet   PracticeSet @relation(fields: [practiceSetId], references: [id], onDelete: Cascade)

  @@index([practiceSetId])
  @@map("practice_questions")
}

model EvidencePaper {
  id         String          @id @default(uuid())
  userId     String          @map("user_id")
  title      String
  authors    String?
  year       Int?
  venue      String?
  documentId String          @map("document_id")
  tags       Json?
  createdAt  DateTime        @default(now()) @map("created_at")

  document   ContentDocument @relation(fields: [documentId], references: [id])
  cards      EvidenceCard[]

  @@index([userId])
  @@map("evidence_papers")
}

model EvidenceCard {
  id                 String        @id @default(uuid())
  evidencePaperId    String        @map("evidence_paper_id")
  claim              String
  recommendation     String
  boundaryConditions String?       @map("boundary_conditions")
  strength           String        // WEAK | MODERATE | STRONG
  tags               Json?
  createdAt          DateTime      @default(now()) @map("created_at")

  paper              EvidencePaper @relation(fields: [evidencePaperId], references: [id], onDelete: Cascade)

  @@index([evidencePaperId])
  @@map("evidence_cards")
}

model AttemptCitation {
  id        String         @id @default(uuid())
  attemptId String         @map("attempt_id")
  chunkId   String         @map("chunk_id")
  rank      Int
  snippet   String
  createdAt DateTime       @default(now()) @map("created_at")

  attempt   SessionAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  chunk     ContentChunk   @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@unique([attemptId, chunkId], map: "attempt_citations_attempt_chunk_key")
  @@index([attemptId])
  @@index([chunkId])
  @@map("attempt_citations")
}

model StudyPlanItem {
  id        String    @id @default(uuid())
  planId    String    @map("plan_id")
  sessionId String    @map("session_id")
  dayIndex  Int       @map("day_index")
  startTime DateTime  @map("start_time") @db.Timestamptz
  endTime   DateTime  @map("end_time") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at")

  plan      StudyPlan @relation(fields: [planId], references: [planId])

  @@unique([planId, sessionId], map: "study_plan_items_plan_id_session_id_key")
  @@index([planId])
  @@map("study_plan_items")
}
