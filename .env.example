# ==============================================================
# Study Bot environment configuration
#
# Quick start: run `npm run setup` — it copies this file to .env,
# generates the secrets marked "auto-filled" below, starts the
# database via Docker, and applies migrations.
# ==============================================================

# --- Database -------------------------------------------------
# Matches docker-compose.yml, which maps Postgres to HOST port 5433
# (5433 avoids clashing with a locally installed Postgres on 5432).
# If you run your own Postgres instead of Docker, point this at it.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/studybot?schema=public"

# --- App URLs -------------------------------------------------
BASE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Authentication (NextAuth) --------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""                       # auto-filled by `npm run setup` (or: openssl rand -base64 32)

# --- Admin & Security -----------------------------------------
ADMIN_USER_IDS=""                        # comma-separated user UUIDs allowed to access /admin
CRON_SECRET=""                           # auto-filled by `npm run setup` — shared secret for cron/internal endpoints

# WARNING: ALLOW_TEST_AUTH makes the app trust the X-User-Id header
# as the authenticated identity. It exists ONLY for automated tests.
# It must NEVER be set in production — leave it commented out.
# ALLOW_TEST_AUTH="true"

# --- Logging --------------------------------------------------
LOG_LEVEL="info"                         # debug | info | warn | error

# --- Push Notifications (Web Push / VAPID) --------------------
VAPID_PUBLIC_KEY=""                      # generate with: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@studybot.app"

# --- Email Reminders ------------------------------------------
EMAIL_PROVIDER="console"                # console | smtp
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Study Bot <noreply@studybot.app>"

# --- Google Calendar Integration ------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI=""                  # defaults to BASE_URL + /api/integrations/google/callback
TOKEN_ENC_KEY=""                        # auto-filled by `npm run setup` — 32 bytes: 64 hex chars or 44 base64 chars (required in production)
GOOGLE_PROVIDER="fake"                 # fake | real — use "fake" in test/CI, "real" in production
GOOGLE_SYNC_CONCURRENCY="3"            # max concurrent Google API calls during publish

# --- AI Control Plane -----------------------------------------
AI_PROVIDER="mock"                     # mock | openai
OPENAI_API_KEY=""                      # required when AI_PROVIDER="openai"
AI_MODEL_ANSWER="gpt-4o-mini"
AI_MODEL_EMBED="text-embedding-3-small"
AI_REQUEST_TIMEOUT_MS="60000"            # abort AI provider requests after this many ms
AI_CACHE_TTL_SECONDS="3600"
AI_DAILY_COST_CAP_USD="1.0"              # max spend per user per day (default $1)
AI_MONTHLY_COST_CAP_USD="10.0"           # max spend per user per month (default $10)
AI_DISABLED="false"                      # emergency kill switch — set "true" to block all AI calls

# --- Background Worker ----------------------------------------
JOB_WORKER_CONCURRENCY="2"
JOB_POLL_INTERVAL_MS="2000"

# --- Hybrid Search --------------------------------------------
HYBRID_SEARCH_ENABLED="false"
